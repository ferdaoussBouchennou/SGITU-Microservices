# ================================================================
#  SGITU — Variables d'environnement (Docker Compose)
#  Copiez ce fichier vers .env et remplissez les valeurs :
#    cp .env.example .env
#
#  Chaque groupe n'ajoute que SA section (G4 = bloc ci-dessous uniquement).
# ================================================================

# ================Configuration des bases de données pour chaque service ================
# -- G1:service billetterie --
billetterie_MONGO_ROOT_USERNAME=admin
billetterie_MONGO_ROOT_PASSWORD=admin
billetterie_MONGO_DATABASE=billetterie_db

# -- G2:abonnement service --
abonnement_DB_NAME=abonnement_db
abonnement_DB_USER=abonnement
abonnement_DB_PASSWORD=abonnement
abonnement_DB_ROOT_PASSWORD=abonnement

# -- Observabilité (Prometheus + Grafana) —
# Mot de passe du compte "admin" de Grafana (http://localhost:3000, login: admin)
GRAFANA_ADMIN_PASSWORD=admin123

# -- G3:service name --
users_DB_NAME=users_db
users_DB_USER=user
users_DB_PASSWORD=user
users_DB_ROOT_PASSWORD=user

# -- G4:service coordination transport (Groupe G4 — ne modifier que ce bloc) --
g4_DB_NAME=sgitu_g4
g4_DB_USER=g4
g4_DB_PASSWORD=g4
# true = intégration promo (chauffeur validé chez G3). Dev Postman G4 seul : false dans ton .env local.
SGITU_G3_VALIDATION_ENABLED=true

# -- G5:service name --
#-- MySQL
MYSQL_ROOT_PASSWORD=root_sgitu_2026
MYSQL_PASSWORD=sgitu_pass_2026

# - JWT (à synchroniser avec G10) —
JWT_SECRET=sgitu-super-secret-key-notifications-2026

# - Email-
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=TON_APP_PASSWORD_GMAIL
MAIL_FROM=your_email@gmail.com

# - SMS -
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+212600000000


# -- G6:service name --

# -- G7:service suivi de vehicule  --
suivi_vehicule_DB_NAME=g7_vehicules
suivi_vehicule_DB_USER=postgres
suivi_vehicule_DB_PASSWORD=password
suivi_vehicule_DB_ROOT_PASSWORD=password
# -- G8:service analytique --
analyse_donnees_DB_NAME=
analyse_donnees_DB_USER=
analyse_donnees_DB_PASSWORD=
analyse_donnees_DB_ROOT_PASSWORD=
# -- G9:service name --

# ================Configuration des variables propres a chaque service================
# -- G3: Service Utilisateur --
JWT_SECRET=your_jwt_secret_here_min_256_bits
JWT_EXPIRATION=86400


# ================Configuration des URLs de chaque service (pour les communications internes)================
G1_BASE_URL=http://service-billetterie:8081
G2_BASE_URL=http://g2-abonnement:8082
G3_BASE_URL=http://g3-service:8083
G4_BASE_URL=http://g4-coordination:8084
G5_BASE_URL=http://g5-service:8085
G6_BASE_URL=http://service-paiement:8086
G7_BASE_URL=http://g7-suivi-vehicule:8087
G8_BASE_URL=http://g8-analytics-service:8088
G9_BASE_URL=http://g9-service:8089
G10_BASE_URL=http://g10-service:8090
