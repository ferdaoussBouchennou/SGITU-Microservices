\ProvidesPackage{beamercolorthemeuae}[2026/05/27 UAE ENSA Beamer colors]

\definecolor{UAEDarkBlue}{RGB}{0,51,102}
\definecolor{UAELightBlue}{RGB}{0,102,153}
\definecolor{UAESkyBlue}{RGB}{100,149,193}
\definecolor{UAEAccentGold}{RGB}{198,156,47}
\definecolor{UAETextGray}{RGB}{64,64,64}

\setbeamercolor{normal text}{fg=UAETextGray,bg=white}
\setbeamercolor{structure}{fg=UAEDarkBlue}
\setbeamercolor{alerted text}{fg=UAEAccentGold}
\setbeamercolor{example text}{fg=UAELightBlue}

\setbeamercolor*{palette primary}{use=structure,fg=white,bg=UAEDarkBlue}
\setbeamercolor*{palette secondary}{use=structure,fg=UAEDarkBlue,bg=UAESkyBlue!25}
\setbeamercolor*{palette tertiary}{use=structure,fg=white,bg=UAELightBlue}
\setbeamercolor*{palette quaternary}{use=structure,fg=UAEDarkBlue,bg=UAESkyBlue!15}

\setbeamercolor*{titlelike}{parent=palette primary}
\setbeamercolor*{frametitle}{fg=white,bg=UAEDarkBlue}
\setbeamercolor*{framesubtitle}{fg=UAESkyBlue!40,bg=UAEDarkBlue}

\setbeamercolor*{block title}{use=structure,fg=white,bg=UAELightBlue}
\setbeamercolor*{block body}{use=structure,fg=UAETextGray,bg=UAESkyBlue!12}
\setbeamercolor*{block title alerted}{use=alerted text,fg=white,bg=UAEAccentGold!90!black}
\setbeamercolor*{block body alerted}{use=alerted text,fg=UAETextGray,bg=UAEAccentGold!15}
\setbeamercolor*{block title example}{use=example text,fg=white,bg=UAEDarkBlue!85}
\setbeamercolor*{block body example}{use=example text,fg=UAETextGray,bg=UAELightBlue!10}

\setbeamercolor*{sidebar}{use=palette primary}
\setbeamercolor*{section in head/foot}{fg=white,bg=UAEDarkBlue}
\setbeamercolor*{subsection in head/foot}{fg=white,bg=UAELightBlue}
\setbeamercolor*{author in head/foot}{fg=white,bg=UAEDarkBlue}
\setbeamercolor*{title in head/foot}{fg=white,bg=UAEDarkBlue}
\setbeamercolor*{date in head/foot}{fg=white,bg=UAEDarkBlue}

\setbeamercolor*{item}{fg=UAELightBlue}
\setbeamercolor*{subitem}{fg=UAESkyBlue}
\setbeamercolor*{subsubitem}{fg=UAESkyBlue!80!black}

\setbeamercolor*{footline}{fg=white,bg=UAEDarkBlue}
\setbeamercolor*{progress bar}{fg=UAEAccentGold,bg=UAESkyBlue!30}

\endinput
