		{
			"name": "Send Notifications",
			"item": [
				{
					"name": "Send Email Notification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notificationId\": \"{{$guid}}\",\n  \"sourceService\": \"G6_PAYMENT\",\n  \"eventType\": \"PAYMENT_SUCCESS\",\n  \"channel\": \"EMAIL\",\n  \"priority\": \"HIGH\",\n  \"recipient\": {\n    \"userId\": \"user-123\",\n    \"email\": \"test.client@example.com\"\n  },\n  \"metadata\": {\n    \"data\": {\n      \"amount\": \"150 MAD\",\n      \"clientName\": \"Mohamed\"\n    }\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notifications/send",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications",
								"send"
							]
						},
						"description": "Sends an email notification via SMTP (MailHog in dev)."
					},
					"response": []
				},
				{
					"name": "Send SMS Notification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notificationId\": \"{{$guid}}\",\n  \"sourceService\": \"G9_INCIDENT\",\n  \"eventType\": \"INCIDENT_CONFIRMATION\",\n  \"channel\": \"SMS\",\n  \"priority\": \"NORMAL\",\n  \"recipient\": {\n    \"userId\": \"user-456\",\n    \"phone\": \"+212600000000\"\n  },\n  \"metadata\": {\n    \"data\": {\n      \"incidentId\": \"INC-2026\"\n    }\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notifications/send",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications",
								"send"
							]
						},
						"description": "Sends an SMS notification via Twilio SMS."
					},
					"response": []
				},
				{
					"name": "Send Push Notification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notificationId\": \"{{$guid}}\",\n  \"sourceService\": \"G4_COORDINATION\",\n  \"eventType\": \"MISSION_ASSIGNED\",\n  \"channel\": \"PUSH\",\n  \"priority\": \"HIGH\",\n  \"recipient\": {\n    \"userId\": \"user-789\",\n    \"deviceToken\": \"fcm-token-example-123456\"\n  },\n  \"metadata\": {\n    \"data\": {\n      \"missionId\": \"M-9988\",\n      \"driverName\": \"Youssef\"\n    }\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notifications/send",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications",
								"send"
							]
						},
						"description": "Sends a mobile push notification via FCM."
					},
					"response": []
				}
			]
		},
		{
			"name": "Dynamic Filtering & Lists",
			"item": [
				{
					"name": "List All (No Filters)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notifications?page=0&size=20&sort=createdAt,desc",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications"
							],
							"query": [
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "20"
								},
								{
									"key": "sort",
									"value": "createdAt,desc"
								}
							]
						},
						"description": "Returns a paginated list of all notifications sorted from newest to oldest."
					},
					"response": []
				},
				{
					"name": "Filter by User ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notifications?userId=user-123",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications"
							],
							"query": [
								{
									"key": "userId",
									"value": "user-123"
								}
							]
						},
						"description": "Retrieves only notifications matching the specified userId."
					},
					"response": []
				},
				{
					"name": "Filter by Status (SENT)",
