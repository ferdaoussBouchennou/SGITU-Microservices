					},
					"response": []
				},
				{
					"name": "Combined Filters (User + Status + Service)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notifications?userId=user-123&status=SENT&sourceService=G6_PAYMENT",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications"
							],
							"query": [
								{
									"key": "userId",
									"value": "user-123"
								},
								{
									"key": "status",
									"value": "SENT"
								},
								{
									"key": "sourceService",
									"value": "G6_PAYMENT"
								}
							]
						},
						"description": "Retrieves notifications satisfying all multiple criteria at once."
					},
					"response": []
				},
				{
