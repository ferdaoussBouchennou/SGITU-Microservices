					"name": "Filter by Source Service",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notifications?sourceService=G6_PAYMENT",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications"
							],
							"query": [
								{
									"key": "sourceService",
									"value": "G6_PAYMENT"
								}
							]
