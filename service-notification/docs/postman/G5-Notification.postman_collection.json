							"raw": "{{baseUrl}}/api/notifications?status=SENT",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications"
							],
							"query": [
								{
									"key": "status",
									"value": "SENT"
								}
							]
						},
						"description": "Filters notifications to display only those that have been sent successfully."
					},
					"response": []
				},
				{
					"name": "Filter by Status (FAILED)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notifications?status=FAILED",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"notifications"
							],
							"query": [
								{
									"key": "status",
									"value": "FAILED"
