    {
      "name": "3. Resilience (retry + circuit breaker)",
      "item": [
        {
          "name": "POST /send SMS (echec attendu) -> QUEUED",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "pm.collectionVariables.set('smsNotificationId', 'sms-fail-' + Date.now());"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 202 (QUEUED)', () => pm.response.to.have.status(202));",
              "pm.collectionVariables.set('smsNotificationId', pm.response.json().notificationId);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{userToken}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"notificationId\": \"{{smsNotificationId}}\",\n  \"sourceService\": \"G1_BILLETTERIE\",\n  \"eventType\": \"TICKET_CREATED\",\n  \"channel\": \"SMS\",\n  \"priority\": \"NORMAL\",\n  \"recipient\": { \"userId\": \"123\", \"phone\": \"+212600000000\" }\n}" },
            "url": { "raw": "{{baseUrl}}/api/notifications/send", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "send"] },
            "description": "SMS sans Twilio configuré : accepté (202) puis l'envoi échoue de façon asynchrone -> passera FAILED après les tentatives. Sert à tester le retry et le circuit breaker."
          }
        },
        {
          "name": "Pause (laisser l'async + retries se terminer)",
          "event": [ { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
            "// Petite attente pour laisser le traitement asynchrone avancer.",
            "const ms = 3000; const end = Date.now() + ms; while (Date.now() < end) {}"
          ] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('OK', () => pm.expect(true).to.be.true);" ] } } ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/notifications/health", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "health"] },
            "description": "Requête tampon avec ~3s d'attente avant de consulter le statut du SMS."
          }
        },
        {
          "name": "GET statut SMS (PENDING/FAILED/SENT)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "if (j.id) pm.collectionVariables.set('lastInternalId', j.id);",
            "pm.test('Statut connu', () => pm.expect(['PENDING','FAILED','SENT']).to.include(j.status));",
            "console.log('Statut SMS =', j.status, '| retryCount =', j.retryCount);"
          ] } } ],
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{userToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/notifications/{{smsNotificationId}}", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "{{smsNotificationId}}"] },
            "description": "Observe le statut et le retryCount du SMS (le backoff exponentiel peut le laisser PENDING un moment, puis FAILED)."
          }
        },
        {
          "name": "POST /{id}/retry (relance manuelle)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('202 (relance) ou 400 (statut != FAILED)', () => pm.expect([202,400]).to.include(pm.response.code));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{userToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/notifications/{{smsNotificationId}}/retry", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "{{smsNotificationId}}", "retry"] },
            "description": "Relance manuelle : 202 si la notif est FAILED, sinon 400 (retry non applicable). Max 3 tentatives, backoff exponentiel."
          }
        },
        {
          "name": "GET circuit breaker (prometheus)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const t = pm.response.text();",
            "pm.test('Etat circuit breaker expose', () => pm.expect(t).to.include('resilience4j_circuitbreaker_state'));",
            "const closed = /resilience4j_circuitbreaker_state\\{[^}]*name=\"notificationProvider\"[^}]*state=\"closed\"[^}]*\\}\\s+([0-9.]+)/.exec(t);",
            "console.log('Etat CLOSED gauge =', closed ? closed[1] : 'n/a (etats agreges)');"
          ] } } ],
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{userToken}}" } ],
            "url": { "raw": "{{baseUrl}}/actuator/prometheus", "host": ["{{baseUrl}}"], "path": ["actuator", "prometheus"] },
            "description": "Vérifie l'état du circuit breaker 'notificationProvider' (CLOSED/OPEN/HALF_OPEN). Il s'ouvre si >= 50% d'échecs sur 10 appels."
          }
        }
      ]
    },
