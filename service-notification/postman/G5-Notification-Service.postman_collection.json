            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{userToken}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"notificationId\": \"{{idempotentId}}\",\n  \"sourceService\": \"G4_COORDINATION\",\n  \"eventType\": \"IDEMPOTENCE_TEST\",\n  \"channel\": \"LOG\",\n  \"priority\": \"LOW\",\n  \"recipient\": { \"userId\": \"123\" }\n}" },
